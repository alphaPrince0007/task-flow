{
  "info": {
    "name": "TaskFlow API",
    "description": "Task Management System — auth, tasks CRUD, and admin endpoints. Auth uses HTTP-only cookies, so run 'Login' first; Postman stores the cookie and subsequent requests are authenticated automatically. Set the {{baseUrl}} variable (default http://localhost:3000).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "taskId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Passw0rd\"\n}" }
          }
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@taskflow.dev\",\n  \"password\": \"Admin@123\"\n}" }
          }
        },
        {
          "name": "Login (User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@taskflow.dev\",\n  \"password\": \"User@123\"\n}" }
          }
        },
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] }
          }
        },
        {
          "name": "Update my profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Name\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List tasks (filtered)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks?page=1&limit=10&sortBy=createdAt&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sortBy", "value": "createdAt" },
                { "key": "sortOrder", "value": "desc" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "status", "value": "PENDING", "disabled": true },
                { "key": "priority", "value": "HIGH", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Task stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/tasks/stats", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "stats"] }
          }
        },
        {
          "name": "Create task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Save the new task id for the update/delete requests.",
                  "const json = pm.response.json();",
                  "if (json?.data?.task?.id) pm.collectionVariables.set('taskId', json.data.task.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/tasks", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Task from Postman\",\n  \"description\": \"Created via the collection\",\n  \"status\": \"PENDING\",\n  \"priority\": \"HIGH\"\n}" }
          }
        },
        {
          "name": "Get task by id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "{{taskId}}"] }
          }
        },
        {
          "name": "Update task",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "{{taskId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"COMPLETED\"\n}" }
          }
        },
        {
          "name": "Delete task",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v1/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "{{taskId}}"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List all users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const first = json?.data?.users?.find(u => u.role === 'USER');",
                  "if (first) pm.collectionVariables.set('userId', first.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"] }
          }
        },
        {
          "name": "Change user role",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/users/{{userId}}/role", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{userId}}", "role"] },
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"ADMIN\"\n}" }
          }
        },
        {
          "name": "Delete user",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v1/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{userId}}"] }
          }
        }
      ]
    }
  ]
}
