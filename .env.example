# ─────────────────────────────────────────────────────────────
# TaskFlow environment variables
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# DATABASE
# Default: SQLite (zero-setup — the DB is just a local file).
DATABASE_URL="file:./dev.db"

# To use PostgreSQL instead (e.g. Neon / Supabase / local Postgres):
#   1. Set the URL below.
#   2. In prisma/schema.prisma change:  provider = "sqlite"  ->  provider = "postgresql"
#   3. Run:  npm run prisma:generate && npm run prisma:push && npm run db:seed
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/taskflow?schema=public"

# JWT / AUTH
# Secret used to sign access & refresh tokens. MUST be long and random in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars-long"

# Token lifetimes
ACCESS_TOKEN_TTL="15m"    # short-lived access token
REFRESH_TOKEN_TTL="7d"    # long-lived refresh token

# APP
NODE_ENV="development"
